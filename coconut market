<div class="app">
  <!-- ШАПКА -->
  <div class="header">
    <div class="logo"><span>КОКОС</span><span>МАРКЕТ</span></div>
    <div class="nav">
      <button class="nav-btn active" data-tab="home" data-i18n="home">🏠 Главная</button>
      <button class="nav-btn" data-tab="favorites" data-i18n="favorites">❤️ Избранное</button>
      <button class="nav-btn" data-tab="profile" data-i18n="profile">👤 Профиль</button>
      <button class="nav-btn" data-tab="add" data-i18n="add">➕ Добавить</button>
    </div>
    <div id="authArea">
      <button class="user-icon" id="loginBtn" style="display: flex;">👤</button>
      <button class="user-icon" id="userIconBtn" style="display: none;">👤</button>
    </div>
  </div>

  <!-- ВКЛАДКИ -->
  <div class="content">
    <div id="home" class="tab active">
      <h2 style="color:#4e3927; margin-bottom:20px;" data-i18n="all_products">Все товары</h2>
      <div id="productsContainer" class="products-grid">
        <p style="color:#7f6b58;" data-i18n="login_to_see">Войдите, чтобы увидеть товары</p>
      </div>
    </div>
    <div id="favorites" class="tab">
      <h2 style="color:#4e3927; margin-bottom:20px;" data-i18n="favorites_title">Избранное</h2>
      <div id="favoritesContainer" class="products-grid">
        <p style="color:#7f6b58;" data-i18n="no_favorites">Вы пока ничего не добавили в избранное</p>
      </div>
    </div>
    <div id="profile" class="tab">
      <div class="profile-header">
        <img class="profile-avatar" id="profileAvatar" src="https://via.placeholder.com/80?text=🥥" alt="avatar">
        <div class="profile-info">
          <div class="profile-name" id="profileDisplayName">Гость</div>
          <div style="color:#7f6b58;" id="profileEmail"></div>
        </div>
        <button class="menu-btn" id="profileMenuBtn">⋮</button>
      </div>
      <div class="context-menu" id="contextMenu">
        <div class="context-item" data-action="orders" data-i18n="all_orders">📦 Все заказы</div>
        <div class="context-item" data-action="returns" data-i18n="returns">↩️ Возвраты</div>
        <div class="context-item" data-action="balance" data-i18n="balance">💰 Баланс средств (Кокос Коин)</div>
        <div class="context-item" data-action="premium" data-i18n="premium">👑 Кокос Маркет Премиум</div>
        <div class="context-item" data-action="mymarket" data-i18n="my_market">🏪 Мой маркет</div>
        <div class="context-item" data-action="settings" data-i18n="settings">⚙️ Настройки</div>
      </div>
      <div class="profile-section">
        <h3 data-i18n="my_products">📦 Мои товары</h3>
        <div id="myProductsContainer" class="products-grid"><p style="color:#7f6b58;">Загрузка...</p></div>
      </div>
      <div class="profile-section">
        <h3 data-i18n="rejected_products">❌ Отклонённые товары</h3>
        <div id="rejectedContainer" class="products-grid"><p style="color:#7f6b58;">Загрузка...</p></div>
      </div>
      <div style="display: flex; gap: 12px;">
        <button class="btn" id="supportBtn" style="flex:1;" data-i18n="support">🎧 Поддержка</button>
        <button class="btn" id="randomCocosBtn" style="flex:1;" data-i18n="random_cocos">🎲 Рандом Кокос</button>
      </div>
    </div>
    <div id="add" class="tab">
      <div class="add-form">
        <h2 style="color:#4e3927; margin-bottom:24px;" data-i18n="add_product">➕ Добавить товар</h2>
        <div class="input-group"><label data-i18n="title">Название</label><input type="text" id="productTitle" placeholder="Кокосовый торт"></div>
        <div class="input-group"><label data-i18n="description">Описание</label><textarea id="productDesc" rows="3" placeholder="Подробное описание товара"></textarea></div>
        <div class="input-group"><label data-i18n="characteristics">Характеристики</label><input type="text" id="productSpecs" placeholder="Вес: 1 кг, Размер: 20 см"></div>
        <div class="input-group"><label data-i18n="price">Цена (₽)</label><input type="number" id="productPrice" placeholder="350"></div>
        <div class="input-group"><label data-i18n="location">Откуда отправка</label><input type="text" id="productLocation" placeholder="г. Москва, ул. Пальмовая, 5"></div>
        <div class="input-group">
          <label data-i18n="photos">Фото (до 5 шт.)</label>
          <input type="file" id="productPhotos" accept="image/*" multiple>
          <div id="photoPreview" class="photo-preview"></div>
        </div>
        <div style="display:flex; align-items:center; gap:10px; margin:20px 0;">
          <input type="checkbox" id="agreeCheckbox">
          <label for="agreeCheckbox" data-i18n="agree">Я соглашаюсь с лицензионным соглашением Кокос</label>
        </div>
        <button class="btn" id="submitProductBtn" data-i18n="submit">🚀 Отправить на модерацию</button>
        <div id="addMessage" style="margin-top:16px;"></div>
      </div>
    </div>
  </div>

  <!-- МОДАЛЬНОЕ ОКНО ВХОДА -->
  <div id="loginModal" class="modal">
    <div class="modal-content">
      <h2 style="color:#4e3927; margin-bottom:20px;" data-i18n="login_title">Вход в Кокос Маркет</h2>
      <div id="emailStep">
        <div class="input-group"><label data-i18n="email">Твой Email</label><input type="email" id="loginEmail" placeholder="friend@example.com"></div>
        <div class="input-group"><label data-i18n="name">Твоё имя</label><input type="text" id="loginNameInput" placeholder="Тимофей"></div>
        <button class="btn" id="sendCodeBtn" data-i18n="get_code">📧 Получить код</button>
        <div id="emailMessage" style="margin-top:12px;"></div>
      </div>
      <div id="codeStep" style="display:none;">
        <div class="input-group"><label data-i18n="code">Код из письма (6 цифр)</label><input type="text" id="loginCode" placeholder="000000" maxlength="6"></div>
        <button class="btn" id="verifyCodeBtn" data-i18n="confirm">✅ Подтвердить</button>
        <div id="codeMessage" style="margin-top:12px;"></div>
        <p style="margin-top:20px; cursor:pointer;" id="backToEmailBtn" data-i18n="back">← Назад</p>
      </div>
    </div>
  </div>

  <!-- МОДАЛЬНОЕ ОКНО ТОВАРА -->
  <div id="productModal" class="modal">
    <div class="modal-content" style="max-width: 500px; padding: 20px;">
      <div style="display: flex; justify-content: flex-end; margin-bottom: 8px;">
        <button id="closeProductModal" style="background: none; border: none; font-size: 24px; cursor: pointer;">✕</button>
      </div>
      <div id="productDetailContent"></div>
    </div>
  </div>

  <!-- МОДАЛЬНОЕ ОКНО НАСТРОЕК -->
  <div id="settingsModal" class="modal">
    <div class="modal-content">
      <h2 style="color:#4e3927; margin-bottom:20px;" data-i18n="settings_title">⚙️ Настройки</h2>
      <div style="display: flex; flex-direction: column; gap: 12px;">
        <button class="btn" id="changeAvatarBtn" data-i18n="change_avatar">📸 Сменить фото профиля</button>
        <button class="btn" id="changePublicNameBtn" data-i18n="change_name">✏️ Публичное имя</button>
        <button class="btn" id="myAccountBtn" data-i18n="my_account">👤 Мой аккаунт</button>
        <button class="btn" id="notificationsBtn" data-i18n="notifications">🔔 Уведомления</button>
        <button class="btn" id="currencyBtn" data-i18n="currency">💱 Валюта</button>
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <span data-i18n="dark_theme">🌙 Тёмная тема</span>
          <input type="checkbox" id="themeToggle">
        </div>
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <span data-i18n="language">🌐 Язык</span>
          <select id="languageSelect" style="padding: 8px; border-radius: 20px;">
            <option value="ru">Русский</option>
            <option value="en">English</option>
            <option value="zh">中文</option>
            <option value="bg">Български</option>
          </select>
        </div>
      </div>
      <button class="btn" id="closeSettingsBtn" style="margin-top: 20px;" data-i18n="close">Закрыть</button>
    </div>
  </div>

  <!-- МОДАЛЬНОЕ ОКНО СПИСКА (заказы / маркет) -->
  <div id="listModal" class="modal">
    <div class="modal-content" style="max-width: 500px;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
        <h2 id="listModalTitle">Список</h2>
        <button id="closeListModal" style="background: none; border: none; font-size: 24px; cursor: pointer;">✕</button>
      </div>
      <div id="listModalContent"></div>
    </div>
  </div>

  <!-- МОДАЛЬНОЕ ОКНО РУЛЕТКИ -->
  <div id="rouletteModal" class="modal">
    <div class="modal-content" style="text-align: center;">
      <h2 data-i18n="roulette">🎰 Кокос Рулетка</h2>
      <p><span data-i18n="prize">Выпал приз:</span> <strong id="prizeResult">🥥 10 Кокос Коин</strong></p>
      <button class="btn" id="spinRouletteBtn" data-i18n="spin">🎲 Крутить</button>
      <button class="btn" id="closeRouletteBtn" style="margin-top: 12px;" data-i18n="close">Закрыть</button>
    </div>
  </div>

  <!-- ПОПАП ПРОФИЛЯ -->
  <div class="profile-popup" id="profilePopup">
    <div style="font-weight:bold; font-size:18px; margin-bottom:10px;" id="profilePopupName"></div>
    <button class="logout-btn" id="logoutBtn" data-i18n="logout">🚪 Выйти</button>
  </div>
</div>

