<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
  <title>Кокос Маркет 🥥</title>
  <style>
    * { box-sizing: border-box; margin: 0; font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif; }
    body { background: #f7f3e9; min-height: 100vh; padding: 12px; }
    .app { max-width: 1200px; margin: 0 auto; }
    .header { display: flex; justify-content: space-between; align-items: center; padding: 16px 0; flex-wrap: wrap; gap: 12px; }
    .logo { font-size: 32px; font-weight: 700; color: #5c3f2b; }
    .logo span:first-child { color: #6b4f3c; } .logo span:last-child { color: #d4a373; }
    .nav { display: flex; gap: 8px; flex-wrap: wrap; }
    .nav-btn { background: #f1e9dd; border: none; font-size: 16px; font-weight: 500; color: #5c3f2b; cursor: pointer; padding: 12px 18px; border-radius: 30px; transition: 0.2s; min-height: 48px; touch-action: manipulation; }
    .nav-btn.active { background: #d4a373; color: white; }
    .user-icon { background: #f1e9dd; width: 48px; height: 48px; border-radius: 30px; display: flex; align-items: center; justify-content: center; font-size: 24px; cursor: pointer; border: none; touch-action: manipulation; }
    .content { margin-top: 24px; }
    .tab { display: none; }
    .tab.active { display: block; }
    .products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; }
    .product-card { background: white; border-radius: 24px; padding: 16px; box-shadow: 0 8px 16px rgba(0,0,0,0.05); border: 1px solid #e9dccd; cursor: pointer; transition: transform 0.1s; touch-action: manipulation; position: relative; }
    .product-card:hover { transform: scale(1.02); }
    .product-image { width: 100%; height: 160px; object-fit: cover; border-radius: 16px; margin-bottom: 12px; background: #e9dccd; }
    .product-title { font-weight: 700; font-size: 18px; margin-bottom: 4px; color: #3f2e1f; }
    .product-price { font-weight: bold; color: #6b4f3c; margin-bottom: 8px; }
    .btn { background: #d4a373; color: white; border: none; padding: 14px 20px; border-radius: 40px; font-weight: bold; cursor: pointer; width: 100%; min-height: 52px; touch-action: manipulation; }
    .btn:disabled { opacity: 0.6; cursor: not-allowed; }
    .input-group { margin-bottom: 18px; }
    .input-group label { display: block; font-weight: 500; color: #5c4432; margin-bottom: 6px; }
    .input-group input, .input-group textarea { width: 100%; padding: 14px; border: 2px solid #ddd2c4; border-radius: 24px; outline: none; background: white; font-size: 16px; }
    .add-form { background: white; border-radius: 32px; padding: 24px; max-width: 600px; margin: 0 auto; }
    .photo-preview { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 10px; }
    .photo-preview img { width: 80px; height: 80px; object-fit: cover; border-radius: 12px; border: 2px solid #d4a373; }
    .modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: none; align-items: center; justify-content: center; z-index: 1000; }
    .modal.show { display: flex; }
    .modal-content { background: white; max-width: 400px; width: 90%; border-radius: 32px; padding: 24px; max-height: 90vh; overflow-y: auto; }
    .profile-popup { position: absolute; top: 70px; right: 20px; background: white; border-radius: 28px; box-shadow: 0 10px 30px rgba(0,0,0,0.15); padding: 20px; display: none; border: 1px solid #e9dccd; z-index: 50; }
    .profile-popup.show { display: block; }
    .logout-btn { background: #eee4da; border: none; padding: 14px; border-radius: 40px; width: 100%; font-weight: 600; cursor: pointer; min-height: 52px; touch-action: manipulation; }
    .carousel { position: relative; margin-bottom: 16px; }
    .carousel-main { width: 100%; height: 250px; object-fit: contain; border-radius: 20px; background: #f3ede5; }
    .carousel-thumbs { display: flex; gap: 8px; margin-top: 8px; overflow-x: auto; }
    .carousel-thumb { width: 60px; height: 60px; object-fit: cover; border-radius: 12px; cursor: pointer; border: 2px solid transparent; touch-action: manipulation; }
    .carousel-thumb.active { border-color: #d4a373; }
    .carousel-nav { display: flex; justify-content: center; gap: 20px; margin-top: 8px; }
    .carousel-btn { background: none; border: none; font-size: 24px; cursor: pointer; color: #6b4f3c; padding: 8px; min-width: 44px; min-height: 44px; touch-action: manipulation; }
    /* Профиль */
    .profile-header { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; }
    .profile-avatar { width: 80px; height: 80px; border-radius: 50%; object-fit: cover; background: #e9dccd; }
    .profile-info { flex: 1; }
    .profile-name { font-size: 24px; font-weight: 700; color: #3f2e1f; }
    .menu-btn { background: none; border: none; font-size: 28px; cursor: pointer; color: #5c3f2b; padding: 8px; min-width: 48px; min-height: 48px; touch-action: manipulation; }
    .context-menu { background: white; border-radius: 24px; box-shadow: 0 8px 20px rgba(0,0,0,0.1); padding: 8px; margin-bottom: 24px; display: none; }
    .context-menu.show { display: block; }
    .context-item { padding: 14px 16px; border-radius: 16px; cursor: pointer; font-weight: 500; min-height: 52px; display: flex; align-items: center; touch-action: manipulation; }
    .context-item:hover { background: #f3ede5; }
    .profile-section { background: white; border-radius: 24px; padding: 20px; margin-bottom: 24px; }
    .profile-section h3 { color: #4e3927; margin-bottom: 16px; }
    /* Сердечко */
    .favorite-btn { position: absolute; top: 12px; right: 12px; background: white; border-radius: 50%; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 4px 8px rgba(0,0,0,0.1); border: none; font-size: 20px; z-index: 5; touch-action: manipulation; }
    .favorite-btn.active { color: #ff4d6d; }
    /* Тёмная тема */
    body.dark { background: #1e1e1e; }
    body.dark .app .logo, body.dark .product-title, body.dark .profile-name { color: #f0e6d2; }
    body.dark .btn, body.dark .nav-btn.active { background: #b4845c; }
    body.dark .modal-content, body.dark .product-card, body.dark .profile-section, body.dark .context-menu, body.dark .add-form { background: #2d2d2d; color: #eee; border-color: #555; }
    /* Тач-оптимизация */
    button, .btn, .nav-btn, .user-icon, .product-card, .context-item, .carousel-btn, .logout-btn, .favorite-btn {
      -webkit-tap-highlight-color: transparent;
      user-select: none;
    }
    input, textarea, select { font-size: 16px; }
  </style>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
